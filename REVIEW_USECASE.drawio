<mxfile host="app.diagrams.net" modified="2026-03-26T00:00:00.000Z" agent="GitHub Copilot" version="21.0.0" type="device">
  <diagram id="review-usecase" name="Review Use Case Diagram">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="Use Case Diagram — Đánh Giá Sản Phẩm (Product Review)" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=20;fontStyle=1;fontColor=#1a237e;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="900" height="40" as="geometry"/>
        </mxCell>

        <!-- System boundary -->
        <mxCell id="sys" value="&lt;&lt;System&gt;&gt;&#xa;Product Review — /api/reviews/**" style="swimlane;startSize=50;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="280" y="80" width="980" height="680" as="geometry"/>
        </mxCell>

        <!-- Constraint note -->
        <mxCell id="note_rule" value="⚠️ Điều kiện tạo đánh giá:&#xa;1. orderedProductId = order_line.id hợp lệ&#xa;2. Đơn hàng thuộc về user&#xa;3. Trạng thái đơn = DELIVERED&#xa;4. Chỉ đánh giá 1 lần / order_line&#xa;5. ratingValue: 1–5 sao" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="700" y="90" width="270" height="120" as="geometry"/>
        </mxCell>

        <!-- UC1: View by Product (Public) -->
        <mxCell id="uc1" value="UC1&#xa;Xem Đánh Giá Theo Sản Phẩm&#xa;GET /api/reviews/product/{id}" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="390" y="150" width="260" height="80" as="geometry"/>
        </mxCell>

        <!-- UC2: Summary (Public) -->
        <mxCell id="uc2" value="UC2&#xa;Xem Thống Kê Đánh Giá&#xa;GET /api/reviews/product/{id}/summary" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="390" y="270" width="260" height="80" as="geometry"/>
        </mxCell>

        <!-- UC3: Create Review (Auth) -->
        <mxCell id="uc3" value="UC3&#xa;Tạo Đánh Giá&#xa;POST /api/reviews" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="390" y="390" width="260" height="80" as="geometry"/>
        </mxCell>

        <!-- UC4: My Reviews (Auth) -->
        <mxCell id="uc4" value="UC4&#xa;Xem Đánh Giá Của Tôi&#xa;GET /api/reviews/my" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="390" y="510" width="260" height="80" as="geometry"/>
        </mxCell>

        <!-- UC5: Delete Review (Auth) -->
        <mxCell id="uc5" value="UC5&#xa;Xóa Đánh Giá&#xa;DELETE /api/reviews/{id}" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="390" y="630" width="260" height="80" as="geometry"/>
        </mxCell>

        <!-- Include: Check OrderLine -->
        <mxCell id="inc1" value="&lt;&lt;include&gt;&gt;&#xa;Kiểm Tra OrderLine Hợp Lệ&#xa;(thuộc về user)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="760" y="330" width="230" height="75" as="geometry"/>
        </mxCell>

        <!-- Include: Check Delivered -->
        <mxCell id="inc2" value="&lt;&lt;include&gt;&gt;&#xa;Kiểm Tra Trạng Thái&#xa;status == DELIVERED" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="760" y="430" width="230" height="75" as="geometry"/>
        </mxCell>

        <!-- Include: Check Duplicate -->
        <mxCell id="inc3" value="&lt;&lt;include&gt;&gt;&#xa;Kiểm Tra Chưa Đánh Giá&#xa;existsByUserIdAndOrderedProductId" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="760" y="530" width="230" height="75" as="geometry"/>
        </mxCell>

        <!-- Include: Batch Load -->
        <mxCell id="inc4" value="&lt;&lt;include&gt;&gt;&#xa;Batch Load Thông Tin&#xa;Product / Color / Size" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="760" y="160" width="230" height="75" as="geometry"/>
        </mxCell>

        <!-- Auth note -->
        <mxCell id="note_auth" value="🔒 UC3, UC4, UC5&#xa;yêu cầu JWT token" style="shape=note;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="310" y="445" width="60" height="65" as="geometry"/>
        </mxCell>

        <!-- Actor: Guest -->
        <mxCell id="guest" value="👤 Guest&#xa;(Khách)" style="shape=mxgraph.flowchart.actor;fillColor=#f5f5f5;strokeColor=#666666;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="190" width="80" height="110" as="geometry"/>
        </mxCell>

        <!-- Actor: User -->
        <mxCell id="user" value="👤 User&#xa;(Thành Viên)" style="shape=mxgraph.flowchart.actor;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="500" width="80" height="110" as="geometry"/>
        </mxCell>

        <!-- Edges: Guest → UC1, UC2 -->
        <mxCell id="eg1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="guest" target="uc1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="eg2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="guest" target="uc2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Edges: User → UC3, UC4, UC5 -->
        <mxCell id="eu3" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="user" target="uc3" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="eu4" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="user" target="uc4" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="eu5" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="user" target="uc5" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Edges: UC → includes -->
        <mxCell id="ei1" value="&lt;&lt;include&gt;&gt;" style="edgeStyle=orthogonalEdgeStyle;dashed=1;endArrow=open;" edge="1" source="uc3" target="inc1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ei2" value="&lt;&lt;include&gt;&gt;" style="edgeStyle=orthogonalEdgeStyle;dashed=1;endArrow=open;" edge="1" source="uc3" target="inc2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ei3" value="&lt;&lt;include&gt;&gt;" style="edgeStyle=orthogonalEdgeStyle;dashed=1;endArrow=open;" edge="1" source="uc3" target="inc3" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ei4" value="&lt;&lt;include&gt;&gt;" style="edgeStyle=orthogonalEdgeStyle;dashed=1;endArrow=open;" edge="1" source="uc1" target="inc4" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ei5" value="&lt;&lt;include&gt;&gt;" style="edgeStyle=orthogonalEdgeStyle;dashed=1;endArrow=open;" edge="1" source="uc4" target="inc4" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="create-review-seq" name="UC3 — Tạo Đánh Giá (Sequence)">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
