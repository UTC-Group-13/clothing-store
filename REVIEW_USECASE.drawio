        <mxCell id="e3" value="❌ 404&#xa;review.orderLineNotFound" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1"><mxGeometry x="660" y="547" width="175" height="40" as="geometry"/></mxCell>

        <!-- ② Order belongs to user -->
