        <mxCell id="u_id"   value="🔑 id (PK)"  style="text;html=1;strokeColor=none;fillColor=none;fontSize=11;align=left;" vertex="1" parent="t_user"><mxGeometry x="8" y="35" width="160" height="22" as="geometry"/></mxCell>
