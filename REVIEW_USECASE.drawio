        <mxCell id="r_cat"   value="created_at"                            style="text;html=1;strokeColor=none;fillColor=none;fontSize=11;align=left;" vertex="1" parent="t_review"><mxGeometry x="8" y="145" width="195" height="22" as="geometry"/></mxCell>
