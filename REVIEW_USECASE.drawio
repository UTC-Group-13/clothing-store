        <mxCell id="l_id"   value="🔑 id (PK)"                          style="text;html=1;strokeColor=none;fillColor=none;fontSize=11;align=left;" vertex="1" parent="t_line"><mxGeometry x="8" y="35" width="195" height="22" as="geometry"/></mxCell>
        <mxCell id="l_oid"  value="🔗 order_id (FK → shop_order)"        style="text;html=1;strokeColor=none;fillColor=none;fontSize=11;align=left;" vertex="1" parent="t_line"><mxGeometry x="8" y="57" width="195" height="22" as="geometry"/></mxCell>
        <mxCell id="l_vsid" value="🔗 variant_stock_id"                  style="text;html=1;strokeColor=none;fillColor=none;fontSize=11;align=left;" vertex="1" parent="t_line"><mxGeometry x="8" y="79" width="195" height="22" as="geometry"/></mxCell>
        <mxCell id="l_qty"  value="qty, price"                           style="text;html=1;strokeColor=none;fillColor=none;fontSize=11;align=left;" vertex="1" parent="t_line"><mxGeometry x="8" y="101" width="195" height="22" as="geometry"/></mxCell>

