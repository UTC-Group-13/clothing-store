        <mxCell id="title" value="UC3 — Sequence Diagram: Tạo Đánh Giá Sản Phẩm (createReview)" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=16;fontStyle=1;fontColor=#1a237e;" vertex="1" parent="1">
          <mxGeometry x="80" y="20" width="1300" height="35" as="geometry"/>
        </mxCell>

        <!-- Lifeline headers -->
        <mxCell id="lh1" value="👤 User"             style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;fontStyle=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="20"   y="70" width="100" height="45" as="geometry"/></mxCell>
        <mxCell id="lh2" value="🔒 JwtFilter"        style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;fontSize=10;" vertex="1" parent="1"><mxGeometry x="155"  y="70" width="115" height="45" as="geometry"/></mxCell>
        <mxCell id="lh3" value="🌐 ReviewController" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=10;" vertex="1" parent="1"><mxGeometry x="305"  y="70" width="130" height="45" as="geometry"/></mxCell>
        <mxCell id="lh4" value="⚙️ ReviewServiceImpl" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=10;" vertex="1" parent="1"><mxGeometry x="470"  y="70" width="140" height="45" as="geometry"/></mxCell>
        <mxCell id="lh5" value="🗄️ UserRepository"   style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=10;" vertex="1" parent="1"><mxGeometry x="645"  y="70" width="130" height="45" as="geometry"/></mxCell>
        <mxCell id="lh6" value="🗄️ OrderLineRepo"    style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=10;" vertex="1" parent="1"><mxGeometry x="810"  y="70" width="130" height="45" as="geometry"/></mxCell>
        <mxCell id="lh7" value="🗄️ OrderRepository"  style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=10;" vertex="1" parent="1"><mxGeometry x="975"  y="70" width="130" height="45" as="geometry"/></mxCell>
        <mxCell id="lh8" value="🗄️ StatusRepository" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=10;" vertex="1" parent="1"><mxGeometry x="1140" y="70" width="130" height="45" as="geometry"/></mxCell>
        <mxCell id="lh9" value="🗄️ ReviewRepository" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;fontSize=10;" vertex="1" parent="1"><mxGeometry x="1310" y="70" width="130" height="45" as="geometry"/></mxCell>

        <!-- Lifelines -->
        <mxCell id="ll1" style="edgeStyle=none;dashed=1;endArrow=none;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="70"   y="115"/><mxPoint x="70"   y="1080"/></Array></mxGeometry></mxCell>
        <mxCell id="ll2" style="edgeStyle=none;dashed=1;endArrow=none;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="213"  y="115"/><mxPoint x="213"  y="1080"/></Array></mxGeometry></mxCell>
        <mxCell id="ll3" style="edgeStyle=none;dashed=1;endArrow=none;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="370"  y="115"/><mxPoint x="370"  y="1080"/></Array></mxGeometry></mxCell>
        <mxCell id="ll4" style="edgeStyle=none;dashed=1;endArrow=none;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="540"  y="115"/><mxPoint x="540"  y="1080"/></Array></mxGeometry></mxCell>
        <mxCell id="ll5" style="edgeStyle=none;dashed=1;endArrow=none;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="710"  y="115"/><mxPoint x="710"  y="1080"/></Array></mxGeometry></mxCell>
        <mxCell id="ll6" style="edgeStyle=none;dashed=1;endArrow=none;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="875"  y="115"/><mxPoint x="875"  y="1080"/></Array></mxGeometry></mxCell>
        <mxCell id="ll7" style="edgeStyle=none;dashed=1;endArrow=none;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1040" y="115"/><mxPoint x="1040" y="1080"/></Array></mxGeometry></mxCell>
        <mxCell id="ll8" style="edgeStyle=none;dashed=1;endArrow=none;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1205" y="115"/><mxPoint x="1205" y="1080"/></Array></mxGeometry></mxCell>
        <mxCell id="ll9" style="edgeStyle=none;dashed=1;endArrow=none;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1375" y="115"/><mxPoint x="1375" y="1080"/></Array></mxGeometry></mxCell>

        <!-- Step 1: Request -->
        <mxCell id="s1" value="POST /api/reviews { orderedProductId:12, ratingValue:5, comment:... }" style="html=1;fontSize=10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="70" y="165"/><mxPoint x="213" y="165"/></Array></mxGeometry></mxCell>
        <mxCell id="b_jwt" value="Xác thực JWT → username" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="1"><mxGeometry x="153" y="175" width="125" height="28" as="geometry"/></mxCell>
        <mxCell id="err_jwt" value="❌ 401" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1"><mxGeometry x="10" y="178" width="55" height="28" as="geometry"/></mxCell>

        <mxCell id="s2" value="Request authenticated" style="html=1;fontSize=10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="213" y="220"/><mxPoint x="370" y="220"/></Array></mxGeometry></mxCell>
        <mxCell id="b_valid" value="@Valid: orderedProductId NotNull, ratingValue 1-5" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1"><mxGeometry x="300" y="232" width="215" height="28" as="geometry"/></mxCell>

        <mxCell id="s3" value="createReview(username, request)" style="html=1;fontSize=10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="370" y="278"/><mxPoint x="540" y="278"/></Array></mxGeometry></mxCell>

        <!-- ① User -->
        <mxCell id="n1" value="① Lấy SiteUser" style="shape=callout;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="470" y="290" width="135" height="25" as="geometry"/></mxCell>
        <mxCell id="s4"  value="findByUsername(username)"   style="html=1;fontSize=10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="540" y="325"/><mxPoint x="710" y="325"/></Array></mxGeometry></mxCell>
        <mxCell id="s4r" value="SiteUser { id }"            style="html=1;dashed=1;fontSize=10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="710" y="338"/><mxPoint x="540" y="338"/></Array></mxGeometry></mxCell>

        <!-- ② OrderLine -->
        <mxCell id="n2" value="② Kiểm tra OrderLine" style="shape=callout;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="470" y="350" width="155" height="25" as="geometry"/></mxCell>
        <mxCell id="s5"  value="findById(orderedProductId)"  style="html=1;fontSize=10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="540" y="385"/><mxPoint x="875" y="385"/></Array></mxGeometry></mxCell>
        <mxCell id="s5r" value="OrderLine { orderId, variantStockId }" style="html=1;dashed=1;fontSize=10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="875" y="400"/><mxPoint x="540" y="400"/></Array></mxGeometry></mxCell>
        <mxCell id="err2" value="❌ 404 review.orderLineNotFound" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1"><mxGeometry x="885" y="378" width="185" height="30" as="geometry"/></mxCell>

        <!-- ③ Order belongs to user -->
        <mxCell id="n3" value="③ Kiểm tra Order thuộc user" style="shape=callout;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="470" y="415" width="195" height="25" as="geometry"/></mxCell>
        <mxCell id="s6"  value="findById(orderLine.orderId)" style="html=1;fontSize=10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="540" y="450"/><mxPoint x="1040" y="450"/></Array></mxGeometry></mxCell>
        <mxCell id="s6r" value="ShopOrder { userId, orderStatus }" style="html=1;dashed=1;fontSize=10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1040" y="465"/><mxPoint x="540" y="465"/></Array></mxGeometry></mxCell>
        <mxCell id="b_owner" value="order.userId == user.id?" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1"><mxGeometry x="470" y="478" width="175" height="28" as="geometry"/></mxCell>
        <mxCell id="err3" value="❌ 400 review.notYourOrder" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1"><mxGeometry x="660" y="478" width="175" height="28" as="geometry"/></mxCell>

        <!-- ④ Check DELIVERED -->
        <mxCell id="n4" value="④ Kiểm tra DELIVERED" style="shape=callout;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="470" y="518" width="165" height="25" as="geometry"/></mxCell>
        <mxCell id="s7"  value="findById(order.orderStatus)" style="html=1;fontSize=10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="540" y="555"/><mxPoint x="1205" y="555"/></Array></mxGeometry></mxCell>
        <mxCell id="s7r" value="OrderStatus { status }" style="html=1;dashed=1;fontSize:10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1205" y="570"/><mxPoint x="540" y="570"/></Array></mxGeometry></mxCell>
        <mxCell id="b_del" value="status == 'DELIVERED'?" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1"><mxGeometry x="470" y="583" width="175" height="28" as="geometry"/></mxCell>
        <mxCell id="err4" value="❌ 400 review.orderNotDelivered" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1"><mxGeometry x="660" y="583" width="190" height="28" as="geometry"/></mxCell>

        <!-- ⑤ Check duplicate -->
        <mxCell id="n5" value="⑤ Kiểm tra chưa đánh giá" style="shape=callout;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="470" y="623" width="190" height="25" as="geometry"/></mxCell>
        <mxCell id="s8"  value="existsByUserIdAndOrderedProductId(userId, orderedProductId)" style="html=1;fontSize=10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="540" y="660"/><mxPoint x="1375" y="660"/></Array></mxGeometry></mxCell>
        <mxCell id="s8r" value="false (chưa đánh giá)" style="html=1;dashed=1;fontSize:10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1375" y="675"/><mxPoint x="540" y="675"/></Array></mxGeometry></mxCell>
        <mxCell id="err5" value="❌ 400 review.alreadyReviewed" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1"><mxGeometry x="1385" y="653" width="185" height="30" as="geometry"/></mxCell>

        <!-- ⑥ Save -->
        <mxCell id="n6" value="⑥ Lưu đánh giá" style="shape=callout;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="470" y="692" width="140" height="25" as="geometry"/></mxCell>
        <mxCell id="s9"  value="save(UserReview { userId, orderedProductId, ratingValue, comment })" style="html=1;fontSize:10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="540" y="728"/><mxPoint x="1375" y="728"/></Array></mxGeometry></mxCell>
        <mxCell id="s9r" value="UserReview { id, createdAt }" style="html=1;dashed=1;fontSize:10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1375" y="743"/><mxPoint x="540" y="743"/></Array></mxGeometry></mxCell>

        <!-- ⑦ Enrich -->
        <mxCell id="n7" value="⑦ Enrich: OrderLine → VariantStock → Product/Color/Size" style="shape=callout;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="470" y="760" width="340" height="28" as="geometry"/></mxCell>
        <mxCell id="b_enrich" value="load VariantStock → ProductVariant → Product / Color / Size&#xa;(batch load từ các Map đã có)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1"><mxGeometry x="470" y="800" width="340" height="42" as="geometry"/></mxCell>

        <!-- Return -->
        <mxCell id="s10" value="ReviewResponseDTO { id, username, productName, colorName, sizeLabel, ratingValue, comment, createdAt }" style="html=1;dashed=1;fontSize:10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="540" y="860"/><mxPoint x="370" y="860"/></Array></mxGeometry></mxCell>
        <mxCell id="s11" value="201 Created: { Tạo đánh giá thành công, data: ReviewResponseDTO }" style="html=1;dashed=1;fontSize:10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="370" y="890"/><mxPoint x="70" y="890"/></Array></mxGeometry></mxCell>
      </root>
