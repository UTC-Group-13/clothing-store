        <!-- Business rules box -->
        <mxCell id="rules" value="📋 Ràng Buộc Nghiệp Vụ:&#xa;• UNIQUE (user_id, ordered_product_id) — 1 lần đánh giá / order_line&#xa;• order.user_id == review.user_id — chỉ đánh giá đơn của mình&#xa;• order_status.status == 'DELIVERED' — phải đã nhận hàng&#xa;• ratingValue: 1–5 sao (validated ở DTO layer)" style="shape=note;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
