        <!-- user_review -->
        <mxCell id="t_review" value="user_review" style="swimlane;fontStyle=1;align=center;startSize=30;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;" vertex="1" parent="1"><mxGeometry x="440" y="260" width="210" height="185" as="geometry"/></mxCell>
        <mxCell id="r_id"    value="🔑 id (PK)"                           style="text;html=1;strokeColor=none;fillColor=none;fontSize=11;align=left;" vertex="1" parent="t_review"><mxGeometry x="8" y="35"  width="195" height="22" as="geometry"/></mxCell>
        <mxCell id="r_uid"   value="🔗 user_id (FK → site_users)"          style="text;html=1;strokeColor=none;fillColor=none;fontSize=11;align=left;" vertex="1" parent="t_review"><mxGeometry x="8" y="57"  width="195" height="22" as="geometry"/></mxCell>
        <mxCell id="r_oid"   value="🔗 ordered_product_id (FK → order_line)" style="text;html=1;strokeColor=none;fillColor=none;fontSize=11;align=left;" vertex="1" parent="t_review"><mxGeometry x="8" y="79"  width="195" height="22" as="geometry"/></mxCell>
        <mxCell id="r_rat"   value="rating_value (1–5)"                    style="text;html=1;strokeColor=none;fillColor=none;fontSize=11;align=left;" vertex="1" parent="t_review"><mxGeometry x="8" y="101" width="195" height="22" as="geometry"/></mxCell>
