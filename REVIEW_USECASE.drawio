        <mxCell id="e2" value="❌ 400 Bad Request" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1"><mxGeometry x="660" y="323" width="170" height="40" as="geometry"/></mxCell>

