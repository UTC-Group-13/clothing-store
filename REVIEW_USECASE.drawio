        <mxCell id="o_id"    value="🔑 id (PK)"                  style="text;html=1;strokeColor=none;fillColor=none;fontSize=11;align=left;" vertex="1" parent="t_order"><mxGeometry x="8" y="35" width="185" height="22" as="geometry"/></mxCell>
        <mxCell id="o_uid"   value="🔗 user_id"                  style="text;html=1;strokeColor=none;fillColor=none;fontSize=11;align=left;" vertex="1" parent="t_order"><mxGeometry x="8" y="57" width="185" height="22" as="geometry"/></mxCell>
        <mxCell id="o_stat"  value="🔗 order_status (FK → order_status)" style="text;html=1;strokeColor=none;fillColor=none;fontSize=11;align=left;" vertex="1" parent="t_order"><mxGeometry x="8" y="79" width="185" height="22" as="geometry"/></mxCell>
