        <mxCell id="e_uc3_stock" value="&lt;&lt;include&gt;&gt;" style="edgeStyle=orthogonalEdgeStyle;dashed=1;endArrow=open;" edge="1" source="uc3" target="inc_stock" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_uc1_summary" value="&lt;&lt;include&gt;&gt;" style="edgeStyle=orthogonalEdgeStyle;dashed=1;endArrow=open;" edge="1" source="uc1" target="inc_summary" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_uc2_summary" value="&lt;&lt;include&gt;&gt;" style="edgeStyle=orthogonalEdgeStyle;dashed=1;endArrow=open;" edge="1" source="uc2" target="inc_summary" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

