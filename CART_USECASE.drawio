      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="Use Case Diagram — Giỏ Hàng (Shopping Cart)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=20;fontStyle=1;fontColor=#1a237e;" vertex="1" parent="1">
          <mxGeometry x="350" y="20" width="800" height="40" as="geometry" />
        </mxCell>

        <!-- System boundary -->
        <mxCell id="system" value="&lt;&lt;System&gt;&gt;&#xa;Shopping Cart — /api/cart/**" style="swimlane;startSize=50;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="320" y="80" width="900" height="640" as="geometry" />
        </mxCell>

        <!-- JWT Auth note -->
        <mxCell id="jwt_note" value="⚠️ Tất cả endpoints yêu cầu&#xa;Authorization: Bearer &lt;token&gt;" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fontSize=12;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="640" y="100" width="260" height="60" as="geometry" />
        </mxCell>

        <!-- UC1: View Cart -->
        <mxCell id="uc1" value="UC1&#xa;Xem Giỏ Hàng&#xa;GET /api/cart" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="430" y="190" width="240" height="80" as="geometry" />
        </mxCell>

        <!-- UC2: Add Item -->
        <mxCell id="uc2" value="UC2&#xa;Thêm Sản Phẩm Vào Giỏ&#xa;POST /api/cart/items" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="430" y="310" width="240" height="80" as="geometry" />
        </mxCell>

        <!-- UC3: Update Qty -->
        <mxCell id="uc3" value="UC3&#xa;Cập Nhật Số Lượng&#xa;PUT /api/cart/items/{id}" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="430" y="430" width="240" height="80" as="geometry" />
        </mxCell>

        <!-- UC4: Remove Item -->
        <mxCell id="uc4" value="UC4&#xa;Xóa Sản Phẩm&#xa;DELETE /api/cart/items/{id}" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="430" y="550" width="240" height="80" as="geometry" />
        </mxCell>

        <!-- UC5: Clear Cart -->
        <mxCell id="uc5" value="UC5&#xa;Làm Trống Giỏ Hàng&#xa;DELETE /api/cart" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="430" y="670" width="240" height="80" as="geometry" />
        </mxCell>

        <!-- Include: Check Stock -->
        <mxCell id="inc_stock" value="&lt;&lt;include&gt;&gt;&#xa;Kiểm Tra Tồn Kho&#xa;stockQty &gt;= request.qty" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="780" y="340" width="220" height="80" as="geometry" />
        </mxCell>

        <!-- Include: Get or Create Cart -->
        <mxCell id="inc_cart" value="&lt;&lt;include&gt;&gt;&#xa;Tạo / Lấy Giỏ Hàng&#xa;getOrCreateCart(username)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="780" y="190" width="220" height="80" as="geometry" />
        </mxCell>

        <!-- Extend: Merge Qty -->
        <mxCell id="ext_merge" value="&lt;&lt;extend&gt;&gt;&#xa;Cộng Dồn Số Lượng&#xa;(khi item đã có trong giỏ)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="780" y="460" width="220" height="80" as="geometry" />
        </mxCell>

