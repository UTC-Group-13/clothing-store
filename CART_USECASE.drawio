        <mxCell id="e_u5" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="user_actor" target="uc5" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Edges: UC → includes -->
        <mxCell id="e_uc2_cart" value="&lt;&lt;include&gt;&gt;" style="edgeStyle=orthogonalEdgeStyle;dashed=1;endArrow=open;" edge="1" source="uc2" target="inc_cart" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_uc2_stock" value="&lt;&lt;include&gt;&gt;" style="edgeStyle=orthogonalEdgeStyle;dashed=1;endArrow=open;" edge="1" source="uc2" target="inc_stock" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
