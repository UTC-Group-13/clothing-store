        <mxCell id="err1" value="❌ 401 Unauthorized" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="660" y="215" width="170" height="50" as="geometry" />
        </mxCell>

        <!-- Validation -->
        <mxCell id="d_valid" value="@Valid&#xa;variantStockId ≠ null&#xa;qty ≥ 1?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="390" y="320" width="220" height="90" as="geometry" />
        </mxCell>
        <mxCell id="err2" value="❌ 400 Bad Request" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="660" y="345" width="170" height="50" as="geometry" />
        </mxCell>

        <!-- getOrCreateCart -->
        <mxCell id="f_cart" value="getOrCreateCart(username)&#xa;→ Lấy hoặc tạo mới ShoppingCart" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="380" y="450" width="240" height="60" as="geometry" />
        </mxCell>

        <!-- Find Stock -->
        <mxCell id="f_stock" value="findById(variantStockId)&#xa;từ variant_stock" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="380" y="550" width="240" height="60" as="geometry" />
        </mxCell>

        <!-- Stock found? -->
        <mxCell id="d_found" value="VariantStock&#xa;tồn tại?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="390" y="650" width="220" height="90" as="geometry" />
        </mxCell>
        <mxCell id="err3" value="❌ 404 Not Found&#xa;cart.stockNotFound" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="660" y="675" width="170" height="50" as="geometry" />
        </mxCell>

        <!-- Stock qty check -->
        <mxCell id="d_qty" value="stockQty ≥&#xa;request.qty?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="390" y="780" width="220" height="90" as="geometry" />
        </mxCell>
        <mxCell id="err4" value="❌ 400 Bad Request&#xa;cart.notEnoughStock" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="660" y="805" width="170" height="50" as="geometry" />
        </mxCell>

        <!-- Item exists? -->
        <mxCell id="d_item" value="Item đã có&#xa;trong giỏ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="390" y="910" width="220" height="90" as="geometry" />
        </mxCell>

        <!-- Branch: Item exists -->
        <mxCell id="f_merge" value="newQty = existing.qty + request.qty" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="150" y="1040" width="230" height="50" as="geometry" />
        </mxCell>

        <!-- Check newQty -->
        <mxCell id="d_newqty" value="newQty ≤&#xa;stockQty?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="170" y="1120" width="190" height="90" as="geometry" />
        </mxCell>
        <mxCell id="err5" value="❌ 400&#xa;cart.notEnoughStock" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="30" y="1145" width="130" height="50" as="geometry" />
        </mxCell>

        <!-- Save existing item -->
        <mxCell id="f_save_exist" value="update item.qty = newQty&#xa;cartItemRepository.save()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="160" y="1240" width="210" height="60" as="geometry" />
        </mxCell>

        <!-- Branch: Item not exists -->
        <mxCell id="f_new" value="new ShoppingCartItem(cartId, stockId, qty)&#xa;cartItemRepository.save()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="640" y="1040" width="230" height="60" as="geometry" />
        </mxCell>

        <!-- Build Summary -->
        <mxCell id="f_summary" value="buildCartSummary()&#xa;Batch load: VariantStock, ProductVariant,&#xa;Product, Color, Size&#xa;Tính: priceOverride ?? basePrice&#xa;Tính: subtotal, totalAmount" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="360" y="1340" width="280" height="100" as="geometry" />
        </mxCell>

        <!-- End -->
        <mxCell id="end" value="✅ 200 OK&#xa;CartSummaryDTO" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="390" y="1480" width="220" height="70" as="geometry" />
        </mxCell>

        <!-- Edges -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="start" target="d_jwt" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" value="Không" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="d_jwt" target="err1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" value="Có" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="d_jwt" target="d_valid" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" value="Không" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="d_valid" target="err2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e5" value="Có" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="d_valid" target="f_cart" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="f_cart" target="f_stock" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="f_stock" target="d_found" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e8" value="Không" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="d_found" target="err3" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e9" value="Có" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="d_found" target="d_qty" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e10" value="Không" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="d_qty" target="err4" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e11" value="Có" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="d_qty" target="d_item" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e12" value="Đã có" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="d_item" target="f_merge" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e13" value="Chưa có" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="d_item" target="f_new" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e14" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="f_merge" target="d_newqty" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e15" value="Không" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="d_newqty" target="err5" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e16" value="Có" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="d_newqty" target="f_save_exist" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e17" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="f_save_exist" target="f_summary" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e18" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="f_new" target="f_summary" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e19" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="f_summary" target="end" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
