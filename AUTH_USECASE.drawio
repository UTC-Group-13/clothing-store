  <diagram id="auth-usecase" name="Auth Use Case Diagram">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ===== TITLE ===== -->
        <mxCell id="title" value="Use Case Diagram — Đăng Ký &amp; Đăng Nhập" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1;fontColor=#1a237e;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="700" height="40" as="geometry" />
        </mxCell>

        <!-- ===== SYSTEM BOUNDARY ===== -->
        <mxCell id="system" value="&lt;&lt;System&gt;&gt;&#xa;Clothing Store — Authentication" style="points=[[0,0],[0.25,0],[0.5,0],[0.75,0],[1,0],[1,0.25],[1,0.5],[1,0.75],[1,1],[0.75,1],[0.5,1],[0.25,1],[0,1],[0,0.75],[0,0.5],[0,0.25]];shape=mxgraph.flowchart.start_2;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;verticalAlign=top;spacingTop=10;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="80" width="750" height="550" as="geometry" />
        </mxCell>

        <!-- UC1: Register -->
        <mxCell id="uc1" value="UC1&#xa;Đăng Ký Tài Khoản&#xa;POST /api/auth/register" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="540" y="140" width="260" height="90" as="geometry" />
        </mxCell>

        <!-- UC2: Login -->
        <mxCell id="uc2" value="UC2&#xa;Đăng Nhập&#xa;POST /api/auth/login" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="540" y="270" width="260" height="90" as="geometry" />
        </mxCell>

        <!-- UC3: Change Password -->
        <mxCell id="uc3" value="UC3&#xa;Đổi Mật Khẩu&#xa;POST /api/auth/change-password" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="540" y="400" width="260" height="90" as="geometry" />
        </mxCell>

        <!-- UC4: Use JWT API -->
        <mxCell id="uc4" value="UC4&#xa;Sử Dụng API Cần Auth&#xa;JWT Bearer Token" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="540" y="520" width="260" height="90" as="geometry" />
        </mxCell>

        <!-- SUB UC: Generate Token -->
        <mxCell id="uc_token" value="&lt;&lt;include&gt;&gt;&#xa;Tạo JWT Token&#xa;JwtService.generateToken()" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="840" y="175" width="220" height="80" as="geometry" />
        </mxCell>

        <!-- SUB UC: Validate Token -->
        <mxCell id="uc_validate" value="&lt;&lt;include&gt;&gt;&#xa;Xác Thực JWT Token&#xa;JwtAuthenticationFilter" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="840" y="520" width="220" height="80" as="geometry" />
        </mxCell>

        <!-- SUB UC: Check Duplicate -->
        <mxCell id="uc_dup" value="&lt;&lt;include&gt;&gt;&#xa;Kiểm Tra Username/Email&#xa;Trùng Lặp" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="840" y="305" width="220" height="80" as="geometry" />
        </mxCell>

        <!-- ===== ACTORS ===== -->

        <!-- Guest Actor -->
        <mxCell id="guest_icon" value="Guest&#xa;(Khách)" style="shape=mxgraph.flowchart.actor;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="160" y="220" width="80" height="120" as="geometry" />
        </mxCell>

        <!-- User Actor -->
        <mxCell id="user_icon" value="User&#xa;(Thành Viên)" style="shape=mxgraph.flowchart.actor;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#333333;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="160" y="450" width="80" height="120" as="geometry" />
        </mxCell>

        <!-- Admin Actor -->
        <mxCell id="admin_icon" value="Admin" style="shape=mxgraph.flowchart.actor;fillColor=#ffe6cc;strokeColor=#d79b00;fontColor=#333333;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1200" y="220" width="80" height="120" as="geometry" />
        </mxCell>

        <!-- ===== EDGES — Actor to UC ===== -->

        <!-- Guest → UC1 -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="guest_icon" target="uc1" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Guest → UC2 -->
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="guest_icon" target="uc2" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- User → UC3 -->
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="user_icon" target="uc3" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- User → UC4 -->
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="user_icon" target="uc4" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Admin → UC4 -->
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="admin_icon" target="uc4" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- UC1 → Generate Token (include) -->
        <mxCell id="e6" value="&lt;&lt;include&gt;&gt;" style="edgeStyle=orthogonalEdgeStyle;dashed=1;endArrow=open;" edge="1" source="uc1" target="uc_token" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- UC2 → Generate Token (include) -->
        <mxCell id="e7" value="&lt;&lt;include&gt;&gt;" style="edgeStyle=orthogonalEdgeStyle;dashed=1;endArrow=open;" edge="1" source="uc2" target="uc_token" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- UC1 → Check Duplicate (include) -->
        <mxCell id="e8" value="&lt;&lt;include&gt;&gt;" style="edgeStyle=orthogonalEdgeStyle;dashed=1;endArrow=open;" edge="1" source="uc1" target="uc_dup" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- UC4 → Validate Token (include) -->
        <mxCell id="e9" value="&lt;&lt;include&gt;&gt;" style="edgeStyle=orthogonalEdgeStyle;dashed=1;endArrow=open;" edge="1" source="uc4" target="uc_validate" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ===== PAGE 2: REGISTER SEQUENCE ===== -->
      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="register-flow" name="UC1 — Đăng Ký (Sequence)">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="t1" value="UC1 — Sequence Diagram: Đăng Ký Tài Khoản" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=18;fontStyle=1;fontColor=#1a237e;" vertex="1" parent="1">
          <mxGeometry x="200" y="20" width="900" height="40" as="geometry" />
        </mxCell>

        <!-- Lifeline headers -->
        <mxCell id="lh1" value="👤 Client" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="60" y="80" width="120" height="50" as="geometry" />
        </mxCell>
        <mxCell id="lh2" value="🌐 AuthController" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="260" y="80" width="140" height="50" as="geometry" />
        </mxCell>
        <mxCell id="lh3" value="⚙️ AuthServiceImpl" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="480" y="80" width="140" height="50" as="geometry" />
        </mxCell>
        <mxCell id="lh4" value="🗄️ SiteUserRepository" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="700" y="80" width="150" height="50" as="geometry" />
        </mxCell>
        <mxCell id="lh5" value="🔑 JwtService" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="930" y="80" width="130" height="50" as="geometry" />
        </mxCell>

        <!-- Lifelines (vertical lines) -->
        <mxCell id="ll1" style="edgeStyle=none;html=1;dashed=1;endArrow=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="120" y="130"/><mxPoint x="120" y="860"/></Array></mxGeometry>
        </mxCell>
        <mxCell id="ll2" style="edgeStyle=none;html=1;dashed=1;endArrow=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="330" y="130"/><mxPoint x="330" y="860"/></Array></mxGeometry>
        </mxCell>
        <mxCell id="ll3" style="edgeStyle=none;html=1;dashed=1;endArrow=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="550" y="130"/><mxPoint x="550" y="860"/></Array></mxGeometry>
        </mxCell>
        <mxCell id="ll4" style="edgeStyle=none;html=1;dashed=1;endArrow=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="775" y="130"/><mxPoint x="775" y="860"/></Array></mxGeometry>
        </mxCell>
        <mxCell id="ll5" style="edgeStyle=none;html=1;dashed=1;endArrow=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="995" y="130"/><mxPoint x="995" y="860"/></Array></mxGeometry>
        </mxCell>

        <!-- Step 1: Client → Controller -->
        <mxCell id="s1" value="POST /api/auth/register&#xa;{ username, email, password, phone }" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="120" y="175"/><mxPoint x="330" y="175"/></Array></mxGeometry>
        </mxCell>

        <!-- Validation box -->
        <mxCell id="box1" value="@Valid — Kiểm tra input" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="260" y="195" width="140" height="40" as="geometry" />
        </mxCell>

        <!-- Step 2: Controller → Service -->
        <mxCell id="s2" value="register(RegisterRequest)" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="330" y="255"/><mxPoint x="550" y="255"/></Array></mxGeometry>
        </mxCell>

        <!-- Step 3: Service → DB check username -->
        <mxCell id="s3" value="existsByUsername(username)" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="550" y="290"/><mxPoint x="775" y="290"/></Array></mxGeometry>
        </mxCell>
        <mxCell id="s3r" value="false (chưa tồn tại)" style="edgeStyle=orthogonalEdgeStyle;html=1;dashed=1;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="775" y="310"/><mxPoint x="550" y="310"/></Array></mxGeometry>
        </mxCell>

        <!-- Error box: username exists -->
        <mxCell id="err1" value="❌ Nếu true → throw BusinessException&#xa;400: Username đã tồn tại" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="570" y="270" width="260" height="50" as="geometry" />
        </mxCell>

        <!-- Step 4: Service → DB check email -->
        <mxCell id="s4" value="existsByEmailAddress(email)" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="550" y="360"/><mxPoint x="775" y="360"/></Array></mxGeometry>
        </mxCell>
        <mxCell id="s4r" value="false (chưa tồn tại)" style="edgeStyle=orthogonalEdgeStyle;html=1;dashed=1;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="775" y="380"/><mxPoint x="550" y="380"/></Array></mxGeometry>
        </mxCell>

        <!-- Step 5: BCrypt -->
        <mxCell id="box2" value="BCrypt.encode(password)&#xa;user.setRole(USER)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="480" y="400" width="140" height="50" as="geometry" />
        </mxCell>

        <!-- Step 6: Save -->
        <mxCell id="s5" value="save(SiteUser)" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="550" y="470"/><mxPoint x="775" y="470"/></Array></mxGeometry>
        </mxCell>
        <mxCell id="s5r" value="SiteUser (id, ...)" style="edgeStyle=orthogonalEdgeStyle;html=1;dashed=1;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="775" y="490"/><mxPoint x="550" y="490"/></Array></mxGeometry>
        </mxCell>

        <!-- Step 7: Generate JWT -->
        <mxCell id="s6" value="generateToken(userDetails)" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="550" y="530"/><mxPoint x="995" y="530"/></Array></mxGeometry>
        </mxCell>
        <mxCell id="s6r" value="JWT token (exp: 24h)" style="edgeStyle=orthogonalEdgeStyle;html=1;dashed=1;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="995" y="550"/><mxPoint x="550" y="550"/></Array></mxGeometry>
        </mxCell>

        <!-- Step 8: Return to Controller -->
        <mxCell id="s7" value="AuthResponse { token, userId, username, role }" style="edgeStyle=orthogonalEdgeStyle;html=1;dashed=1;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="550" y="590"/><mxPoint x="330" y="590"/></Array></mxGeometry>
        </mxCell>

        <!-- Step 9: Return to Client -->
        <mxCell id="s8" value="201 Created&#xa;{ success: true, data: { accessToken, tokenType, userId, username, role } }" style="edgeStyle=orthogonalEdgeStyle;html=1;dashed=1;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="330" y="630"/><mxPoint x="120" y="630"/></Array></mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="login-flow" name="UC2 — Đăng Nhập (Sequence)">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="t1" value="UC2 — Sequence Diagram: Đăng Nhập" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=18;fontStyle=1;fontColor=#1a237e;" vertex="1" parent="1">
          <mxGeometry x="200" y="20" width="900" height="40" as="geometry" />
        </mxCell>

        <!-- Lifeline headers -->
        <mxCell id="lh1" value="👤 Client" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="120" height="50" as="geometry" />
        </mxCell>
        <mxCell id="lh2" value="🌐 AuthController" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="220" y="80" width="140" height="50" as="geometry" />
        </mxCell>
        <mxCell id="lh3" value="⚙️ AuthServiceImpl" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="420" y="80" width="140" height="50" as="geometry" />
        </mxCell>
        <mxCell id="lh4" value="🔒 AuthenticationManager" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="620" y="80" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="lh5" value="📋 UserDetailsService" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="840" y="80" width="150" height="50" as="geometry" />
        </mxCell>
        <mxCell id="lh6" value="🗄️ SiteUserRepository" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1050" y="80" width="150" height="50" as="geometry" />
        </mxCell>
        <mxCell id="lh7" value="🔑 JwtService" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1260" y="80" width="130" height="50" as="geometry" />
        </mxCell>

        <!-- Lifelines -->
        <mxCell id="ll1" style="edgeStyle=none;html=1;dashed=1;endArrow=none;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="100" y="130"/><mxPoint x="100" y="870"/></Array></mxGeometry></mxCell>
        <mxCell id="ll2" style="edgeStyle=none;html=1;dashed=1;endArrow=none;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="290" y="130"/><mxPoint x="290" y="870"/></Array></mxGeometry></mxCell>
        <mxCell id="ll3" style="edgeStyle=none;html=1;dashed=1;endArrow=none;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="490" y="130"/><mxPoint x="490" y="870"/></Array></mxGeometry></mxCell>
        <mxCell id="ll4" style="edgeStyle=none;html=1;dashed=1;endArrow=none;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="700" y="130"/><mxPoint x="700" y="870"/></Array></mxGeometry></mxCell>
        <mxCell id="ll5" style="edgeStyle=none;html=1;dashed=1;endArrow=none;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="915" y="130"/><mxPoint x="915" y="870"/></Array></mxGeometry></mxCell>
        <mxCell id="ll6" style="edgeStyle=none;html=1;dashed=1;endArrow=none;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1125" y="130"/><mxPoint x="1125" y="870"/></Array></mxGeometry></mxCell>
        <mxCell id="ll7" style="edgeStyle=none;html=1;dashed=1;endArrow=none;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1325" y="130"/><mxPoint x="1325" y="870"/></Array></mxGeometry></mxCell>

        <!-- Step 1: Client → Controller -->
        <mxCell id="s1" value="POST /api/auth/login { username, password }" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="100" y="175"/><mxPoint x="290" y="175"/></Array></mxGeometry></mxCell>

        <!-- Step 2: Controller → Service -->
        <mxCell id="s2" value="login(LoginRequest)" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="290" y="210"/><mxPoint x="490" y="210"/></Array></mxGeometry></mxCell>

        <!-- Step 3: Service → AuthManager -->
        <mxCell id="s3" value="authenticate(UsernamePasswordAuthenticationToken)" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="490" y="250"/><mxPoint x="700" y="250"/></Array></mxGeometry></mxCell>

        <!-- Step 4: AuthManager → UDS -->
        <mxCell id="s4" value="loadUserByUsername(username)" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="700" y="285"/><mxPoint x="915" y="285"/></Array></mxGeometry></mxCell>

        <!-- Step 5: UDS → DB -->
        <mxCell id="s5" value="findByUsername(username)" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="915" y="315"/><mxPoint x="1125" y="315"/></Array></mxGeometry></mxCell>
        <mxCell id="s5r" value="SiteUser entity" style="edgeStyle=orthogonalEdgeStyle;html=1;dashed=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1125" y="335"/><mxPoint x="915" y="335"/></Array></mxGeometry></mxCell>

        <!-- Step 6: AuthManager verifies password -->
        <mxCell id="box1" value="BCrypt.matches(password, storedHash)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="620" y="360" width="210" height="40" as="geometry" />
        </mxCell>

        <!-- Error: bad credentials -->
        <mxCell id="err1" value="❌ Sai mật khẩu → BadCredentialsException&#xa;→ 401 Unauthorized" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="730" y="360" width="250" height="40" as="geometry" />
        </mxCell>

        <!-- Step 7: Return UserDetails -->
        <mxCell id="s6r" value="UserDetails" style="edgeStyle=orthogonalEdgeStyle;html=1;dashed=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="700" y="420"/><mxPoint x="490" y="420"/></Array></mxGeometry></mxCell>

        <!-- Step 8: Service → DB get user -->
        <mxCell id="s7" value="findByUsername(username)" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="490" y="460"/><mxPoint x="1125" y="460"/></Array></mxGeometry></mxCell>
        <mxCell id="s7r" value="SiteUser" style="edgeStyle=orthogonalEdgeStyle;html=1;dashed=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1125" y="480"/><mxPoint x="490" y="480"/></Array></mxGeometry></mxCell>

        <!-- Step 9: Generate JWT -->
        <mxCell id="s8" value="generateToken(userDetails)" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="490" y="520"/><mxPoint x="1325" y="520"/></Array></mxGeometry></mxCell>
        <mxCell id="s8r" value="JWT token (exp: 24h)" style="edgeStyle=orthogonalEdgeStyle;html=1;dashed=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1325" y="540"/><mxPoint x="490" y="540"/></Array></mxGeometry></mxCell>

        <!-- Step 10: Return to controller -->
        <mxCell id="s9" value="AuthResponse { token, username, role }" style="edgeStyle=orthogonalEdgeStyle;html=1;dashed=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="490" y="580"/><mxPoint x="290" y="580"/></Array></mxGeometry></mxCell>

        <!-- Step 11: Return to client -->
        <mxCell id="s10" value="200 OK { success: true, data: { accessToken, tokenType, userId, username, role } }" style="edgeStyle=orthogonalEdgeStyle;html=1;dashed=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="290" y="620"/><mxPoint x="100" y="620"/></Array></mxGeometry></mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="jwt-filter-flow" name="UC4 — JWT Filter Flow">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="t1" value="UC4 — Flow: Xác Thực JWT Token (JwtAuthenticationFilter)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=18;fontStyle=1;fontColor=#1a237e;" vertex="1" parent="1">
          <mxGeometry x="150" y="20" width="1000" height="40" as="geometry" />
        </mxCell>

        <!-- Start -->
        <mxCell id="start" value="Bắt đầu&#xa;(Request đến server)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="560" y="80" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- Step 1: Get Header -->
        <mxCell id="f1" value="Lấy header&#xa;Authorization: Bearer &lt;token&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="540" y="180" width="220" height="60" as="geometry" />
        </mxCell>

        <!-- Decision: Has token? -->
        <mxCell id="d1" value="Có header &amp;&#xa;bắt đầu 'Bearer '?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="540" y="280" width="220" height="80" as="geometry" />
        </mxCell>

        <!-- No token path -->
        <mxCell id="no1" value="Không có token" style="text;html=1;fontSize=11;fontColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="420" y="290" width="100" height="30" as="geometry" />
        </mxCell>
        <mxCell id="f_no1" value="filterChain.doFilter()&#xa;→ Tiếp tục (anonymous)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="200" y="370" width="200" height="60" as="geometry" />
        </mxCell>

        <!-- Step 2: Extract username -->
        <mxCell id="f2" value="jwtService.extractUsername(token)&#xa;→ Lấy username từ JWT" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="540" y="400" width="220" height="60" as="geometry" />
        </mxCell>

        <!-- Decision: Has username? -->
        <mxCell id="d2" value="username != null &amp;&#xa;chưa authenticated?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="540" y="500" width="220" height="80" as="geometry" />
        </mxCell>

        <!-- Step 3: Load user -->
        <mxCell id="f3" value="userDetailsService.loadUserByUsername()&#xa;→ Load từ DB" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="540" y="620" width="220" height="60" as="geometry" />
        </mxCell>

        <!-- Decision: Token valid? -->
        <mxCell id="d3" value="jwtService.isTokenValid&#xa;(token, userDetails)?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="540" y="720" width="220" height="80" as="geometry" />
        </mxCell>

        <!-- Invalid token path -->
        <mxCell id="f_inv" value="Token hết hạn / không hợp lệ&#xa;→ Bỏ qua (anonymous)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="820" y="730" width="220" height="60" as="geometry" />
        </mxCell>

        <!-- Step 4: Set SecurityContext -->
        <mxCell id="f4" value="SecurityContext.setAuthentication()&#xa;UsernamePasswordAuthenticationToken" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="540" y="840" width="220" height="60" as="geometry" />
        </mxCell>

        <!-- End -->
        <mxCell id="end" value="filterChain.doFilter()&#xa;→ Đến Controller" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="550" y="940" width="200" height="60" as="geometry" />
        </mxCell>

        <!-- Edges -->
        <mxCell id="e_start_f1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="start" target="f1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_f1_d1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="f1" target="d1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_d1_no" value="Không" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="d1" target="f_no1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_d1_yes" value="Có" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="d1" target="f2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_f2_d2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="f2" target="d2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_d2_f3" value="Có" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="d2" target="f3" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_f3_d3" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="f3" target="d3" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_d3_inv" value="Không hợp lệ" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="d3" target="f_inv" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_d3_f4" value="Hợp lệ" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="d3" target="f4" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_f4_end" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="f4" target="end" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_no1_end" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="f_no1" target="end" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

