        <!-- ⑨ OrderLines + deduct stock -->
        <mxCell id="n8" value="⑨ Tạo OrderLines + Trừ tồn kho + Xóa giỏ" style="shape=callout;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="435" y="778" width="260" height="28" as="geometry"/></mxCell>
        <mxCell id="b_loop" value="[loop each cart item]&#xa;save OrderLine; stock.qty -= qty; save stock; deleteByCartId" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1"><mxGeometry x="440" y="818" width="290" height="50" as="geometry"/></mxCell>

        <!-- ⑩ VietQR -->
        <mxCell id="n9" value="⑩ Nếu là chuyển khoản → tạo QR" style="shape=callout;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="435" y="880" width="220" height="28" as="geometry"/></mxCell>
        <mxCell id="s11" value="buildVietQrUrl(bank, amount, orderCode)" style="html=1;fontSize=10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="505" y="920"/><mxPoint x="1480" y="920"/></Array></mxGeometry></mxCell>
        <mxCell id="s11r" value="QR Image URL" style="html=1;dashed=1;fontSize=10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1480" y="935"/><mxPoint x="505" y="935"/></Array></mxGeometry></mxCell>

        <!-- Return -->
