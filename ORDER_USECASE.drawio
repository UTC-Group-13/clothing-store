  <diagram id="place-order-flow" name="UC1 — placeOrder() Flowchart">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="1654" math="0" shadow="0">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>

        <mxCell id="title" value="Flowchart — OrderServiceImpl.placeOrder()" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=16;fontStyle=1;fontColor=#1a237e;" vertex="1" parent="1">
          <mxGeometry x="200" y="20" width="700" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="start" value="▶ POST /api/orders&#xa;{ paymentTypeId, shippingAddressId,&#xa;shippingMethodId, note }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
