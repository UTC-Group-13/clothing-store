        <mxCell id="d2" value="Tìm thấy?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1"><mxGeometry x="380" y="390" width="220" height="70" as="geometry"/></mxCell>
        <mxCell id="e2" value="❌ 404 payment.typeNotFound" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1"><mxGeometry x="650" y="408" width="190" height="40" as="geometry"/></mxCell>

        <!-- ② Address -->
        <mxCell id="f2" value="② existsByUserIdAndAddressId()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1"><mxGeometry x="370" y="500" width="240" height="50" as="geometry"/></mxCell>
        <mxCell id="d3" value="Thuộc user?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1"><mxGeometry x="380" y="590" width="220" height="70" as="geometry"/></mxCell>
        <mxCell id="e3" value="❌ 400 order.addressNotBelongToUser" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1"><mxGeometry x="650" y="608" width="210" height="40" as="geometry"/></mxCell>

        <!-- ③ Shipping -->
        <mxCell id="f3" value="③ findById(shippingMethodId)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1"><mxGeometry x="370" y="700" width="240" height="50" as="geometry"/></mxCell>
        <mxCell id="d4" value="Tìm thấy?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1"><mxGeometry x="380" y="790" width="220" height="70" as="geometry"/></mxCell>
        <mxCell id="e4" value="❌ 404 shipping.notFound" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1"><mxGeometry x="650" y="808" width="190" height="40" as="geometry"/></mxCell>

        <!-- ④ Cart -->
        <mxCell id="f4" value="④ Lấy cartItems của user" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1"><mxGeometry x="370" y="900" width="240" height="50" as="geometry"/></mxCell>
        <mxCell id="d5" value="Giỏ hàng trống?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1"><mxGeometry x="380" y="990" width="220" height="70" as="geometry"/></mxCell>
        <mxCell id="e5" value="❌ 400 order.cartEmpty" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1"><mxGeometry x="650" y="1008" width="190" height="40" as="geometry"/></mxCell>

        <!-- ⑤ Stock -->
        <mxCell id="f5" value="⑤ findAllById(stockIds)&#xa;Loop: stockQty &gt;= item.qty?" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1"><mxGeometry x="370" y="1100" width="240" height="60" as="geometry"/></mxCell>
        <mxCell id="d6" value="Tất cả đủ hàng?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1"><mxGeometry x="380" y="1205" width="220" height="70" as="geometry"/></mxCell>
        <mxCell id="e6" value="❌ 400 order.insufficientStock" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1"><mxGeometry x="650" y="1223" width="190" height="40" as="geometry"/></mxCell>

        <!-- ⑥–⑧ Calculate + Save -->
        <mxCell id="f6" value="⑥ subtotal = Σ(unitPrice × qty)&#xa;orderTotal = subtotal + shippingFee" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1"><mxGeometry x="360" y="1320" width="260" height="60" as="geometry"/></mxCell>
        <mxCell id="f7" value="⑦ Sinh mã: DH + yyyyMMdd + 3 số" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1"><mxGeometry x="360" y="1420" width="260" height="50" as="geometry"/></mxCell>
        <mxCell id="f8" value="⑧ save(ShopOrder) status=PENDING" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1"><mxGeometry x="360" y="1510" width="260" height="50" as="geometry"/></mxCell>
        <mxCell id="f9" value="⑨ Loop: save OrderLine + stock.qty -= qty" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1"><mxGeometry x="360" y="1600" width="260" height="60" as="geometry"/></mxCell>

