  <diagram id="order-status-flow" name="Trạng Thái Đơn Hàng &amp; Thanh Toán">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>

        <mxCell id="title" value="Order Status Flow &amp; Luồng Thanh Toán" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=18;fontStyle=1;fontColor=#1a237e;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="900" height="40" as="geometry"/>
        </mxCell>

        <!-- Status boxes -->
        <mxCell id="st_pending" value="⏳ PENDING&#xa;Chờ xác nhận&#xa;(Tồn kho đã trừ)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="160" y="200" width="180" height="80" as="geometry"/></mxCell>
        <mxCell id="st_proc"    value="⚙️ PROCESSING&#xa;Đang xử lý&#xa;(Admin xác nhận)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="430" y="200" width="180" height="80" as="geometry"/></mxCell>
        <mxCell id="st_ship"   value="🚚 SHIPPING&#xa;Đang giao&#xa;(Shipper lấy hàng)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="700" y="200" width="180" height="80" as="geometry"/></mxCell>
        <mxCell id="st_done"   value="✅ COMPLETED&#xa;Đã nhận hàng&#xa;(Kết thúc)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="970" y="200" width="180" height="80" as="geometry"/></mxCell>
        <mxCell id="st_cancel" value="❌ CANCELLED&#xa;Đã hủy&#xa;(Tồn kho hoàn trả)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="290" y="380" width="180" height="80" as="geometry"/></mxCell>

        <!-- Status transitions -->
        <mxCell id="t1" value="Admin cập nhật" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="st_pending" target="st_proc" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="t2" value="Admin cập nhật" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="st_proc" target="st_ship" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="t3" value="Admin cập nhật" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="st_ship" target="st_done" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="t4" value="User hủy&#xa;(chỉ PENDING)" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#b85450;" edge="1" source="st_pending" target="st_cancel" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Payment section title -->
        <mxCell id="pt" value="─── Luồng Thanh Toán ───" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=16;fontStyle=1;fontColor=#1a237e;" vertex="1" parent="1">
          <mxGeometry x="200" y="520" width="500" height="35" as="geometry"/>
        </mxCell>

        <!-- COD Flow -->
        <mxCell id="cod_title" value="💵 COD (Tiền mặt khi nhận hàng)" style="text;html=1;strokeColor=none;fillColor=none;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="60" y="570" width="350" height="30" as="geometry"/></mxCell>
        <mxCell id="cod1" value="Đặt hàng" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1"><mxGeometry x="60" y="610" width="100" height="50" as="geometry"/></mxCell>
        <mxCell id="cod2" value="PENDING" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1"><mxGeometry x="200" y="610" width="100" height="50" as="geometry"/></mxCell>
        <mxCell id="cod3" value="Giao hàng" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1"><mxGeometry x="340" y="610" width="100" height="50" as="geometry"/></mxCell>
        <mxCell id="cod4" value="Thu tiền + COMPLETED" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1"><mxGeometry x="480" y="610" width="160" height="50" as="geometry"/></mxCell>
        <mxCell id="coda" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="cod1" target="cod2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="codb" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="cod2" target="cod3" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="codc" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="cod3" target="cod4" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Bank Transfer Flow -->
        <mxCell id="bt_title" value="🏦 Bank Transfer (Chuyển khoản + VietQR)" style="text;html=1;strokeColor=none;fillColor=none;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="60" y="700" width="420" height="30" as="geometry"/></mxCell>
        <mxCell id="bt1" value="Đặt hàng" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1"><mxGeometry x="60" y="740" width="90" height="50" as="geometry"/></mxCell>
        <mxCell id="bt2" value="PENDING&#xa;+ QR URL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1"><mxGeometry x="190" y="740" width="100" height="50" as="geometry"/></mxCell>
        <mxCell id="bt3" value="User quét QR&#xa;chuyển khoản" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1"><mxGeometry x="340" y="740" width="110" height="50" as="geometry"/></mxCell>
        <mxCell id="bt4" value="Admin xác nhận&#xa;→ PROCESSING" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1"><mxGeometry x="500" y="740" width="120" height="50" as="geometry"/></mxCell>
        <mxCell id="bt5" value="SHIPPING&#xa;→ COMPLETED" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1"><mxGeometry x="670" y="740" width="120" height="50" as="geometry"/></mxCell>
        <mxCell id="bta" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="bt1" target="bt2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="btb" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="bt2" target="bt3" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="btc" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="bt3" target="bt4" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="btd" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="bt4" target="bt5" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- VietQR note -->
        <mxCell id="qr_note" value="🔗 VietQR URL:&#xa;https://img.vietqr.io/image/{bankId}-{accountNumber}-compact2.png&#xa;?amount={orderTotal}&amp;addInfo={orderCode}&amp;accountName={holderName}" style="shape=note;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="800" y="700" width="500" height="80" as="geometry"/>
        </mxCell>

        <!-- Cancel + restore -->
        <mxCell id="cancel_note" value="🔄 Hủy đơn (PATCH /cancel):&#xa;• Chỉ được hủy khi status = PENDING&#xa;• restoreStock(): stock.qty += line.qty&#xa;• Cập nhật status → CANCELLED" style="shape=note;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="700" y="330" width="330" height="90" as="geometry"/>
        </mxCell>

        <!-- Order code -->
        <mxCell id="code_note" value="📋 Mã đơn hàng:&#xa;Format: DH + yyyyMMdd + 3 chữ số&#xa;Ví dụ: DH20260326001&#xa;→ Dùng làm nội dung chuyển khoản" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1050" y="330" width="280" height="90" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

