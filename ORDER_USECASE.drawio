        <mxCell id="s13" value="201 Created: { Đặt hàng thành công, data: OrderDetailDTO }" style="html=1;dashed=1;fontSize=10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="350" y="1005"/><mxPoint x="70" y="1005"/></Array></mxGeometry></mxCell>
      </root>
    </mxGraphModel>
